{
  "name": "typescript-monorepo-template",
  "version": "0.1.0",
  "private": true,
  "keywords": [
    "typescript",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noshiro-pf/typescript-monorepo-template.git"
  },
  "license": "Apache-2.0",
  "author": "noshiro-pf <noshiro.pf@gmail.com>",
  "sideEffects": false,
  "type": "module",
  "workspaces": [
    "packages/**"
  ],
  "scripts": {
    "check:root": "pnpm run '/check:root:.*/'",
    "check:root:lint": "pnpm run z:eslint ./{scripts,configs}/**/*.mts --fix",
    "check:root:type": "tsc -p ./tsconfig.json --noEmit",
    "check-all": "tsx ./scripts/cmd/check-all.mts",
    "ci:publish": "pnpm run ws:build && pnpm changeset publish",
    "ci:version-packages": "pnpm changeset version && pnpm install --no-frozen-lockfile",
    "clean:node_modules": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "codemod": "run-s codemod:uncommitted:as-const fmt codemod:uncommitted:readonly fmt",
    "codemod:full": "run-s codemod:full:as-const fmt codemod:full:readonly fmt",
    "codemod:full:as-const": "append-as-const 'packages/*/{src,scripts,samples,test}/**/*.{ts,mts,tsx}'",
    "codemod:full:readonly": "convert-to-readonly 'packages/*/{src,scripts,samples,test}/**/*.{ts,mts,tsx}'",
    "codemod:uncommitted:as-const": "append-as-const --uncommitted 'packages/*/{src,scripts,samples,test}/**/*.{ts,mts,tsx}'",
    "codemod:uncommitted:readonly": "convert-to-readonly --uncommitted 'packages/*/{src,scripts,samples,test}/**/*.{ts,mts,tsx}'",
    "cspell": "cspell \"**\" --gitignore --gitignore-root ./ --no-progress",
    "fmt": "format-uncommitted",
    "fmt:diff": "format-diff-from origin/main",
    "fmt:full": "prettier --ignore-unknown --no-error-on-unmatched-pattern --write .",
    "gh:apply-all": "gh-apply-all",
    "gh:apply-repository-settings": "gh-apply-repository-settings",
    "gh:apply-rulesets": "gh-apply-rulesets",
    "gh:apply-variables": "gh-apply-variables",
    "gh:backup-all": "gh-backup-all",
    "gh:backup-repository-settings": "gh-backup-repository-settings",
    "gh:backup-rulesets": "gh-backup-rulesets",
    "md": "markdownlint-cli2",
    "update-dependencies": "pnpm update --latest -r",
    "ws:build": "tsx ./scripts/cmd/ws-build-stages.mts",
    "ws:check:ext": "pnpm run --recursive --if-present check:ext",
    "ws:doc": "pnpm run --recursive --if-present doc",
    "ws:doc:embed": "pnpm run --recursive --if-present doc:embed",
    "ws:doc:embed:jsdoc": "pnpm run --recursive --if-present doc:embed:jsdoc",
    "ws:gi": "pnpm run --recursive --if-present gi",
    "ws:lint": "pnpm run --recursive --if-present lint",
    "ws:lint:fix": "pnpm run --recursive --if-present lint:fix",
    "ws:test": "pnpm run --recursive --if-present test",
    "ws:test:browser": "pnpm run --recursive --if-present test:browser",
    "ws:test:cov": "pnpm run --recursive --if-present test:cov",
    "ws:tsc": "pnpm run --recursive --if-present tsc",
    "ws:type-check": "pnpm run --recursive --if-present type-check",
    "z:eslint": "NODE_OPTIONS='--max-old-space-size=6144' TIMING=1 eslint"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-replace": "6.0.3",
    "@rollup/plugin-strip": "3.0.4",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/node": "25.9.1",
    "@vitest/browser-playwright": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "cspell": "10.0.0",
    "dedent": "1.7.2",
    "eslint": "9.39.4",
    "eslint-config-typed": "4.9.8",
    "github-settings-as-code": "1.2.9",
    "jiti": "2.7.0",
    "markdownlint": "0.40.0",
    "markdownlint-cli2": "0.22.1",
    "npm-run-all2": "8.0.4",
    "playwright": "1.60.0",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-packagejson": "3.0.2",
    "rollup": "4.60.3",
    "ts-codemod-lib": "2.1.7",
    "ts-data-forge": "6.9.6",
    "ts-repo-utils": "10.1.0",
    "ts-type-forge": "3.0.1",
    "tslib": "2.8.1",
    "tsx": "4.21.0",
    "typedoc": "0.28.19",
    "typedoc-github-theme": "0.4.0",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">=9.0.0"
  },
  "volta": {
    "node": "25.9.0"
  }
}
